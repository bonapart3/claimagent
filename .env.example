# =============================================================================
# ClaimAgent™ Environment Configuration (Simplified)
# =============================================================================
# Copy to .env and fill in REQUIRED values. Optional values have defaults.
# =============================================================================

# =============================================================================
# REQUIRED - App will not work without these
# =============================================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/claimagent?schema=public"

# Authentication - CHANGE THESE IN PRODUCTION
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Encryption - MUST be exactly 32 characters
ENCRYPTION_KEY=your-32-character-encryption-key!

# =============================================================================
# REQUIRED FOR AI FEATURES - Skip if not using AI
# =============================================================================

OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# OPTIONAL - Have sensible defaults in code
# =============================================================================

# App Settings (defaults shown)
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_VERSION=3.0.0

# Database Pool (defaults: min=2, max=10, timeout=30000)
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# OpenAI Settings (defaults shown)
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.2

# File Upload (defaults shown)
# UPLOAD_DIR=./uploads
# UPLOAD_MAX_SIZE=10485760

# Rate Limiting (defaults shown)
# RATE_LIMIT_WINDOW=60000
# RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags (defaults: all true except telematics/mobile/multi-lang)
# FEATURE_AUTO_APPROVAL=true
# FEATURE_FRAUD_DETECTION=true
# FEATURE_AI_DAMAGE_ANALYSIS=true

# Auto-Approval Thresholds (defaults shown)
# AUTO_APPROVAL_MAX_AMOUNT=2500
# AUTO_APPROVAL_MIN_CONFIDENCE=0.80

# =============================================================================
# PRODUCTION ONLY - Add these when deploying
# =============================================================================

# External APIs (uncomment and configure as needed)
# VALUATION_API_KEY=your-key
# FRAUD_MODEL_API_KEY=your-key
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# File Storage (choose one)
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_S3_BUCKET=claimagent-documents
# --- OR for Cloudflare R2 ---
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx

# Email (choose one)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email
# SMTP_PASSWORD=app-password
# --- OR ---
# SENDGRID_API_KEY=SG.xxx

# Monitoring (optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXX

# Cloudflare (for Pages deployment)
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_ENABLED=true
